{
  "name": "lichess-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "NODE_ENV=production bun build --minify --compile ./src/index.ts --outfile=dist/bot --target=bun-linux-arm64",
    "format": "oxfmt --list-different || oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@lichess/api": "0.1.1",
    "@stockfish/bun": "0.0.2"
  },
  "devDependencies": {
    "@gameroman/config": "0.1.0",
    "@types/bun": "1.3.14",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3"
  }
}
