{
  "name": "lichess-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "NODE_ENV=production bun build --minify --compile ./src/index.ts --outfile=dist/bot --target=bun-linux-arm64",
    "format": "oxfmt --list-different || oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@lichess/api": "^0.0.4",
    "@stockfish/bun": "^0.0.1"
  },
  "devDependencies": {
    "@gameroman/config": "^0.0.2",
    "@types/bun": "^1.3.10",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3"
  }
}
