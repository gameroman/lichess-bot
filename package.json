{
  "name": "lichess-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "NODE_ENV=production bun build --minify --compile ./src/index.ts --outfile=dist/bot --target=bun-linux-arm64",
    "format": "oxfmt --list-different || oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@lichess/api": "^0.1.1",
    "@stockfish/bun": "^0.0.1"
  },
  "devDependencies": {
    "@gameroman/config": "^0.0.5",
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "^6.0.2"
  }
}
